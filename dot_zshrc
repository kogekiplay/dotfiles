# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
# if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
#   source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
# fi

source /home/lanrhyme/.cachyos-zsh-config.zsh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
# [[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
fastfetch

. "$HOME/.local/bin/env"

# Wayland environment configuration for Fcitx5
export XMODIFIERS=@im=fcitx
export QT_IM_MODULE=fcitx
# GTK_IM_MODULE is handled via settings.ini instead of environment variables to avoid breaking Wayland GTK apps.
# export GTK_IM_MODULE=fcitx



# Added by Antigravity CLI installer
export PATH="/home/lanrhyme/.local/bin:$PATH"

# Initialize Starship Prompt
eval "$(starship init zsh)"

# mimocode
export PATH=/home/lanrhyme/.mimocode/bin:$PATH

# bun completions
[ -s "/home/lanrhyme/.bun/_bun" ] && source "/home/lanrhyme/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

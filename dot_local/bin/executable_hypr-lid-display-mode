#!/usr/bin/env bash
set -euo pipefail

INTERNAL_OUTPUT="${INTERNAL_OUTPUT:-eDP-1}"
EXTERNAL_OUTPUT="${EXTERNAL_OUTPUT:-HDMI-A-1}"

INTERNAL_MODE="${INTERNAL_MODE:-2560x1600@165}"
INTERNAL_SCALE="${INTERNAL_SCALE:-1.6}"
INTERNAL_WITH_EXTERNAL_POS="${INTERNAL_WITH_EXTERNAL_POS:-2560x0}"
INTERNAL_ALONE_POS="${INTERNAL_ALONE_POS:-0x0}"

resolve_hypr_env() {
  if [[ -z "${XDG_RUNTIME_DIR:-}" ]]; then
    XDG_RUNTIME_DIR="/run/user/$(id -u)"
    export XDG_RUNTIME_DIR
  fi

  if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" && -d "${XDG_RUNTIME_DIR}/hypr" ]]; then
    local sig
    sig="$(find "${XDG_RUNTIME_DIR}/hypr" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | head -n 1 || true)"
    if [[ -n "${sig}" ]]; then
      HYPRLAND_INSTANCE_SIGNATURE="${sig}"
      export HYPRLAND_INSTANCE_SIGNATURE
    fi
  fi
}

connector_connected() {
  local output="$1"
  local status
  shopt -s nullglob
  for status in /sys/class/drm/card*-"${output}"/status; do
    if [[ "$(cat "${status}")" == "connected" ]]; then
      return 0
    fi
  done
  return 1
}

lid_state() {
  local state_file
  shopt -s nullglob
  for state_file in /proc/acpi/button/lid/*/state; do
    awk '{print $2}' "${state_file}"
    return 0
  done
  printf 'open\n'
}

restore_internal() {
  local position="${INTERNAL_ALONE_POS}"
  if connector_connected "${EXTERNAL_OUTPUT}"; then
    position="${INTERNAL_WITH_EXTERNAL_POS}"
  fi

  hyprctl eval "hl.monitor({ output = \"${INTERNAL_OUTPUT}\", mode = \"${INTERNAL_MODE}\", position = \"${position}\", scale = ${INTERNAL_SCALE}, disabled = false })"
}

external_only() {
  if ! connector_connected "${EXTERNAL_OUTPUT}"; then
    restore_internal
    return 0
  fi

  hyprctl dispatch focusmonitor "${EXTERNAL_OUTPUT}" >/dev/null 2>&1 || true
  hyprctl eval "hl.monitor({ output = \"${INTERNAL_OUTPUT}\", disabled = true })"
}

main() {
  resolve_hypr_env

  local action="${1:-auto}"
  case "${action}" in
    auto)
      action="$(lid_state)"
      ;;
    on|closed|close)
      action="closed"
      ;;
    off|open)
      action="open"
      ;;
  esac

  case "${action}" in
    closed)
      external_only
      ;;
    open)
      restore_internal
      ;;
    *)
      printf 'unknown lid action: %s\n' "${action}" >&2
      return 2
      ;;
  esac
}

main "$@"

// ────────────── Output Configuration ──────────────
// External 5K monitor. Its EDID marks 2560x1440@60 as preferred, so pin 5K explicitly.
output "HDMI-A-1" {
    mode "5120x2880@165.000"
    scale 2
    position x=0 y=0
}

// Laptop panel.
output "eDP-1" {
    mode "2560x1600@165.000"
    scale 1.5
    position x=2560 y=0
}

{
  "version": "2.3.1",
  "locale": "auto",
  "showIntroductionDialog": true,
  "menuTheme": "default",
  "darkMenuTheme": "default",
  "menuThemeColors": {},
  "darkMenuThemeColors": {},
  "enableDarkModeForMenuThemes": false,
  "enableSelectionWedges": false,
  "soundTheme": "none",
  "soundVolume": 0.5,
  "enableVersionCheck": true,
  "ignoreWriteProtectedConfigFiles": false,
  "settingsWindowColorScheme": "system",
  "settingsWindowFlavor": "transparent-system",
  "trayIconFlavor": "dark",
  "hardwareAcceleration": true,
  "lazyInitialization": false,
  "zoomFactor": 1,
  "hideSettingsButton": false,
  "settingsButtonPosition": "bottom-left",
  "windowsInkWorkaround": true,
  "maxSelectionRadius": 0,
  "centerDeadZone": 30,
  "minParentDistance": 150,
  "dragThreshold": 15,
  "fadeInDuration": 150,
  "fadeOutDuration": 200,
  "keepInputFocus": false,
  "enableMarkingMode": true,
  "enableTurboMode": true,
  "warpMouse": true,
  "hoverModeNeedsConfirmation": false,
  "gestureMinStrokeLength": 50,
  "gestureMinStrokeAngle": 20,
  "gestureJitterThreshold": 10,
  "gesturePauseTimeout": 100,
  "fixedStrokeLength": 0,
  "rmbSelectsParent": false,
  "enableGamepad": true,
  "gamepadBackButton": 1,
  "gamepadCloseButton": 2,
  "sameShortcutBehavior": "close",
  "wlrootsPointerGetTimeoutMouse": 10,
  "wlrootsPointerGetTimeoutTouch": 1500,
  "wlrootsPointerGetTimeoutDefaultBehavior": "bottom-left",
  "useDefaultOsShowSettingsHotkey": true,
  "enableAchievements": true,
  "enableAchievementNotifications": true
}

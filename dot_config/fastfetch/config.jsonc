{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": { "type": "chafa", "source": "/home/kogeki/.config/fastfetch/avatar.png", "width": 40, "height": 19, "padding": { "top": 2, "right": 2 } },
    "display": { "separator": "  ", "disableLinewrap": true, "color": { "keys": "#afac9c", "title": "#f2f2f2" } },
    "modules": [ "title", "separator", { "type": "os", "key": " ΎΝΟ OS" }, { "type": "kernel", "key": " ΎΝ▒ Kernel" }, { "type": "uptime", "key": " ΎΑΩ Uptime" }, { "type": "packages", "key": " ΎΜε Packages" }, { "type": "shell", "key": " ΎΤΚ Shell" }, { "type": "terminal", "key": " ΎΕι Terminal" }, { "type": "display", "key": " ≤░Ξ╣ Display", "format": "({name}): {width}x{height} in {inch}\", {refresh-rate} Hz [{type}]" }, { "type": "de", "key": " ΎΞη DE" }, { "type": "wm", "key": " ΎΜΤ WM" }, "separator", { "type": "host", "key": " ΎΜδ Host" }, { "type": "cpu", "key": " ΎΜδ CPU" }, { "type": "gpu", "key": " ΎΚυ GPU" }, { "type": "memory", "key": " ΎΔν Memory" }, { "type": "disk", "key": " ΎΓι Disk" }, "colors" ]
}

[Unit]
Description=Sync text clipboard between XWayland and Wayland for Linux QQ
After=graphical-session.target

[Service]
Type=simple
Environment=DISPLAY=:0
Environment=WAYLAND_DISPLAY=wayland-1
ExecStart=%h/.local/bin/qq-clipboard-bridge
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
